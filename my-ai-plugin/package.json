{
  "name": "sunpoly-ai-plugin",
  "displayName": "sunpoly-ai-助理",
  "description": "AI 助理插件，支持代码解释、Bug 修复、代码优化、续写和单测生成",
  "version": "0.1.11",
  "publisher": "sunpoly-ai-plugin",
  "author": {
    "name": "Mr.shen",
    "email": "sqf_163@163.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "my-ai-plugin.explain",
        "title": "AI: 解释代码"
      },
      {
        "command": "my-ai-plugin.fix",
        "title": "AI: 修复代码"
      },
      {
        "command": "my-ai-plugin.optimize",
        "title": "AI: 优化代码"
      },
      {
        "command": "my-ai-plugin.complete",
        "title": "AI: 续写代码"
      },
      {
        "command": "my-ai-plugin.test",
        "title": "AI: 生成单测"
      },
      {
        "command": "my-ai-plugin.clearChat",
        "title": "AI: 清空对话"
      },
      {
        "command": "my-ai-plugin.focusChat",
        "title": "AI: 聚焦到聊天输入框"
      },
      {
        "command": "my-ai-plugin.switchMode",
        "title": "AI: 切换工作模式"
      },
      {
        "command": "my-ai-plugin.newChat",
        "title": "AI: 新建对话"
      },
      {
        "command": "my-ai-plugin.openSettings",
        "title": "AI: 打开设置"
      },
      {
        "command": "my-ai-plugin.editModels",
        "title": "AI: 编辑模型配置 (JSON)"
      },
      {
        "command": "my-ai-plugin.newChatTab",
        "title": "AI: 新建聊天 Tab",
        "icon": {
          "light": "resources/add-light.svg",
          "dark": "resources/add-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "my-ai-plugin.explain",
          "group": "ai-plugin@1",
          "when": "editorHasSelection"
        },
        {
          "command": "my-ai-plugin.fix",
          "group": "ai-plugin@2",
          "when": "editorHasSelection"
        },
        {
          "command": "my-ai-plugin.optimize",
          "group": "ai-plugin@3",
          "when": "editorHasSelection"
        },
        {
          "command": "my-ai-plugin.test",
          "group": "ai-plugin@4",
          "when": "editorHasSelection"
        },
        {
          "command": "my-ai-plugin.complete",
          "group": "ai-plugin@5"
        }
      ],
      "editor/title": [
        {
          "command": "my-ai-plugin.newChatTab",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == 'my-ai-plugin.chatTab'"
        }
      ]
    },
    "keybindings": [
      {
        "command": "my-ai-plugin.explain",
        "key": "alt+e",
        "when": "editorHasSelection"
      },
      {
        "command": "my-ai-plugin.fix",
        "key": "alt+f",
        "when": "editorHasSelection"
      },
      {
        "command": "my-ai-plugin.complete",
        "key": "alt+i"
      },
      {
        "command": "my-ai-plugin.optimize",
        "key": "alt+o",
        "when": "editorHasSelection"
      },
      {
        "command": "my-ai-plugin.test",
        "key": "alt+g",
        "when": "editorHasSelection"
      },
      {
        "command": "my-ai-plugin.focusChat",
        "key": "alt+q"
      },
      {
        "command": "my-ai-plugin.switchMode",
        "key": "alt+m"
      },
      {
        "command": "my-ai-plugin.newChat",
        "key": "alt+n"
      },
      {
        "command": "my-ai-plugin.newChatTab",
        "key": "alt+t"
      }
    ],
    "configuration": {
      "title": "AI 助理",
      "properties": {
        "myAiPlugin.models": {
          "type": "array",
          "description": "AI 模型列表，可配置多个模型并快速切换",
          "default": [
            {
              "name": "DeepSeek Chat",
              "modelId": "deepseek-chat",
              "baseUrl": "https://api.deepseek.com",
              "apiKey": "",
              "contextWindow": 64000
            }
          ],
          "items": {
            "type": "object",
            "required": [
              "name",
              "modelId",
              "baseUrl",
              "apiKey"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "模型显示名称（如 DeepSeek Chat、GPT-4o）"
              },
              "modelId": {
                "type": "string",
                "description": "模型 API 标识（如 deepseek-chat、gpt-4o）"
              },
              "baseUrl": {
                "type": "string",
                "description": "API 端点地址（如 https://api.deepseek.com）"
              },
              "apiKey": {
                "type": "string",
                "description": "API 密钥"
              },
              "contextWindow": {
                "type": "number",
                "minimum": 1,
                "description": "模型上下文窗口上限，用于估算当前会话占用；不填时插件会按已知模型或默认兜底值自动推断"
              },
              "apiPath": {
                "type": "string",
                "description": "自定义 API 路径（如 /v1/chat/completions、/chat/completions），不填时默认 /v1/chat/completions"
              }
            }
          }
        },
        "myAiPlugin.activeModelIndex": {
          "type": "number",
          "default": 0,
          "description": "当前使用的模型序号（从 0 开始，对应 models 数组的下标）"
        },
        "myAiPlugin.language": {
          "type": "string",
          "default": "中文",
          "description": "AI 回复语言",
          "enum": [
            "中文",
            "English"
          ]
        },
        "myAiPlugin.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "AI 单次回复的最大 token 数"
        },
        "myAiPlugin.temperature": {
          "type": "number",
          "default": 0.3,
          "description": "AI 回复的随机性（0~1，越低越确定）"
        },
        "myAiPlugin.proxy": {
          "type": "string",
          "default": "",
          "description": "HTTP/HTTPS 代理地址（如 http://127.0.0.1:7890），留空则不使用代理。也会自动读取 VS Code 的 http.proxy 配置。"
        },
        "myAiPlugin.panelTitle": {
          "type": "string",
          "default": "Sunploy",
          "description": "聊天面板标题，可自定义为企业名称（如 SUERY AI、XXX 智能助手）"
        },
        "myAiPlugin.systemPrompt": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "markdownDescription": "自定义系统提示词（System Prompt）。\n\n**非空时**完全覆盖内置提示词；**留空时**使用内置默认提示词。\n\n示例：`你是一个专注 Python 小程序设计的助手，不使用第三方库`"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:csharp && npm run build",
    "build": "node esbuild.js --production",
    "build:csharp": "dotnet build resources/ast_workers/csharp_ast_worker/CsharpAstWorker.csproj -c Debug",
    "watch": "node esbuild.js --watch",
    "test:build": "tsc -p tsconfig.test.json",
    "test": "npm run test:build && node .\\scripts\\run-node-tests.cjs",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ts-morph": "^28.0.0"
  }
}

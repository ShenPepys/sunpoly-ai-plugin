{
  "name": "my-ai-plugin",
  "displayName": "AI 编程助手",
  "description": "VS Code AI 编程助手插件，支持代码解释、Bug 修复、代码优化、续写和单测生成",
  "version": "0.1.0",
  "publisher": "my-ai-plugin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-ai-plugin-sidebar",
          "title": "AI 编程助手",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "my-ai-plugin-sidebar": [
        {
          "type": "webview",
          "id": "my-ai-plugin.chatView",
          "name": "AI 对话"
        }
      ]
    },
    "commands": [
      {
        "command": "my-ai-plugin.explain",
        "title": "AI: 解释代码"
      },
      {
        "command": "my-ai-plugin.fix",
        "title": "AI: 修复代码"
      },
      {
        "command": "my-ai-plugin.optimize",
        "title": "AI: 优化代码"
      },
      {
        "command": "my-ai-plugin.complete",
        "title": "AI: 续写代码"
      },
      {
        "command": "my-ai-plugin.test",
        "title": "AI: 生成单测"
      },
      {
        "command": "my-ai-plugin.clearChat",
        "title": "AI: 清空对话"
      },
      {
        "command": "my-ai-plugin.focusChat",
        "title": "AI: 聚焦到聊天输入框"
      },
      {
        "command": "my-ai-plugin.switchMode",
        "title": "AI: 切换工作模式"
      },
      {
        "command": "my-ai-plugin.newChat",
        "title": "AI: 新建对话"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "my-ai-plugin.explain",
          "group": "ai-plugin@1",
          "when": "editorHasSelection"
        },
        {
          "command": "my-ai-plugin.fix",
          "group": "ai-plugin@2",
          "when": "editorHasSelection"
        },
        {
          "command": "my-ai-plugin.optimize",
          "group": "ai-plugin@3",
          "when": "editorHasSelection"
        },
        {
          "command": "my-ai-plugin.test",
          "group": "ai-plugin@4",
          "when": "editorHasSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "my-ai-plugin.explain",
        "key": "alt+e",
        "when": "editorHasSelection"
      },
      {
        "command": "my-ai-plugin.fix",
        "key": "alt+f",
        "when": "editorHasSelection"
      },
      {
        "command": "my-ai-plugin.focusChat",
        "key": "alt+q"
      },
      {
        "command": "my-ai-plugin.switchMode",
        "key": "alt+m"
      },
      {
        "command": "my-ai-plugin.newChat",
        "key": "alt+n"
      }
    ],
    "configuration": {
      "title": "AI 编程助手",
      "properties": {
        "myAiPlugin.models": {
          "type": "array",
          "description": "AI 模型列表，可配置多个模型并快速切换",
          "default": [
            {
              "name": "DeepSeek Chat",
              "modelId": "deepseek-chat",
              "baseUrl": "https://api.deepseek.com",
              "apiKey": ""
            }
          ],
          "items": {
            "type": "object",
            "required": ["name", "modelId", "baseUrl", "apiKey"],
            "properties": {
              "name": {
                "type": "string",
                "description": "模型显示名称（如 DeepSeek Chat、GPT-4o）"
              },
              "modelId": {
                "type": "string",
                "description": "模型 API 标识（如 deepseek-chat、gpt-4o）"
              },
              "baseUrl": {
                "type": "string",
                "description": "API 端点地址（如 https://api.deepseek.com）"
              },
              "apiKey": {
                "type": "string",
                "description": "API 密钥"
              }
            }
          }
        },
        "myAiPlugin.activeModelIndex": {
          "type": "number",
          "default": 0,
          "description": "当前使用的模型序号（从 0 开始，对应 models 数组的下标）"
        },
        "myAiPlugin.language": {
          "type": "string",
          "default": "中文",
          "description": "AI 回复语言",
          "enum": [
            "中文",
            "English"
          ]
        },
        "myAiPlugin.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "AI 单次回复的最大 token 数"
        },
        "myAiPlugin.temperature": {
          "type": "number",
          "default": 0.3,
          "description": "AI 回复的随机性（0~1，越低越确定）"
        },
        "myAiPlugin.proxy": {
          "type": "string",
          "default": "",
          "description": "HTTP/HTTPS 代理地址（如 http://127.0.0.1:7890），留空则不使用代理。也会自动读取 VS Code 的 http.proxy 配置。"
        },
        "myAiPlugin.panelTitle": {
          "type": "string",
          "default": "AI 编程助手",
          "description": "侧边栏面板标题，可自定义为企业名称（如 SUERY AI、XXX 智能助手）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
